{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",

    "target": "es2023",
    "outDir": "./dist",

    "baseUrl": "./",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "skipLibCheck": true,
    "strictNullChecks": true
  }
}